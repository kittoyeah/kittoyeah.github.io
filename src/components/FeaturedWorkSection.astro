---
import type { FeaturedWork } from "../data/portfolio";
import CaseStudyCard from "./CaseStudyCard.astro";

interface Props {
  works: FeaturedWork[];
}

const { works } = Astro.props;
const total = String(works.length).padStart(2, "0");
---

<section id="work">
  <div class="slab">
    <div class="slab__row">
      <span class="slab__key">Selected work</span>
      <span class="slab__count">{total} pieces</span>
    </div>
  </div>

  <div class="heading">
    <h2 class="heading__title">
      Things I have <em>built</em> and shipped.
    </h2>
    <p class="heading__note">
      One product in live operation, plus two projects that show how I frame
      problems, make decisions, and turn ambiguity into something tangible.
    </p>
  </div>

  <div class="pieces">
    {
      works.map((work, index) => (
        <CaseStudyCard work={work} index={index + 1} />
      ))
    }
  </div>
</section>
