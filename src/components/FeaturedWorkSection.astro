---
import type { FeaturedWork } from "../data/portfolio";
import CaseStudyCard from "./CaseStudyCard.astro";

interface Props {
  works: FeaturedWork[];
}

const { works } = Astro.props;
---

<section class="section" id="work">
  <div class="container">
    <header class="section__head">
      <span class="section__num">02 &mdash; Work</span>
      <h2 class="section__title">
        Three pieces that show how I think and ship.
      </h2>
      <p class="section__lede">
        One product in operation, and two projects that show how I frame a
        problem, make decisions, and turn ambiguity into something tangible.
      </p>
    </header>

    <div class="work-list">
      {
        works.map((work, index) => (
          <CaseStudyCard work={work} index={index + 1} />
        ))
      }
    </div>
  </div>
</section>
