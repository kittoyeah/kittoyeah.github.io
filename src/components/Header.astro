---
import type { SectionLink, SiteConfig } from "../data/portfolio";

interface Props {
  siteConfig: SiteConfig;
  sections: SectionLink[];
}

const { siteConfig, sections } = Astro.props;
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href="#top" aria-label="Back to top">
      <span class="brand__dot" aria-hidden="true"></span>
      <span class="brand__name">CK</span>
      <span class="brand__slash">/</span>
      <span class="brand__role">{siteConfig.role}</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {
        sections.map((section) => (
          <a href={`#${section.id}`} data-num={section.number}>
            {section.label}
          </a>
        ))
      }
    </nav>

    <a
      class="nav-cta"
      href={siteConfig.primaryCta.href}
      rel="noreferrer"
      target="_blank"
    >
      Get in touch
    </a>
  </div>
</header>
