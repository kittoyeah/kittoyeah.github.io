---
import type { SectionLink, SiteConfig } from "../data/portfolio";

interface Props {
  siteConfig: SiteConfig;
  sections: SectionLink[];
}

const { siteConfig, sections } = Astro.props;
---

<header class="banner">
  <div class="banner__row">
    <a class="banner__name" href="#top" aria-label="Back to top">
      Chris Kittichod
    </a>

    <nav class="banner__links" aria-label="Primary">
      {sections.map((section) => <a href={`#${section.id}`}>{section.label}</a>)}
    </nav>

    <a
      class="banner__cta"
      href={siteConfig.primaryCta.href}
      rel="noreferrer"
      target="_blank"
    >
      Say hi →
    </a>
  </div>
</header>
