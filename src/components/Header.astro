---
import type { SectionLink, SiteConfig } from "../data/portfolio";

interface Props {
  siteConfig: SiteConfig;
  sections: SectionLink[];
}

const { siteConfig, sections } = Astro.props;
---

<header class="site-header">
  <a class="wordmark" href="#top" aria-label="Back to top">
    <span class="wordmark__mark">CK</span>
    <span class="wordmark__text">{siteConfig.name}</span>
  </a>

  <nav class="header-nav" aria-label="Primary">
    {
      sections.map((section) => (
        <a href={`#${section.id}`}>{section.label}</a>
      ))
    }
  </nav>

  <a
    class="button button--compact"
    href={siteConfig.primaryCta.href}
    rel="noreferrer"
    target="_blank"
  >
    LinkedIn
  </a>
</header>
