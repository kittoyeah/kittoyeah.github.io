---
import type { EvidenceAsset } from "../data/portfolio";

interface Props {
  assets: EvidenceAsset[];
}

const { assets } = Astro.props;
---

<section id="evidence">
  <div class="slab">
    <div class="slab__row">
      <span class="slab__key">The paper trail</span>
      <span class="slab__count">{assets.length} files</span>
    </div>
  </div>

  <div class="heading">
    <h2 class="heading__title">
      Documents and <em>proof</em>.
    </h2>
    <p class="heading__note">
      An archive of notes, briefs, and supporting material &mdash; kept
      close by without stuffing everything into the main narrative.
    </p>
  </div>

  <div class="files">
    <div class="files__list">
      {
        assets.map((asset, index) => (
          <a class="file-row" href={asset.href} download>
            <span class="file-row__num">
              /{String(index + 1).padStart(2, "0")}
            </span>
            <span class="file-row__title">{asset.title}</span>
            <span class="file-row__note">{asset.note}</span>
            <span class="file-row__type">{asset.type}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>
