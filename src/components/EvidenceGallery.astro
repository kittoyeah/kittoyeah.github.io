---
import type { EvidenceAsset } from "../data/portfolio";

interface Props {
  assets: EvidenceAsset[];
}

const { assets } = Astro.props;
---

<section class="section" id="evidence">
  <div class="container">
    <header class="section__head">
      <span class="section__num">04 &mdash; Evidence</span>
      <h2 class="section__title">Documents, notes, and supporting material.</h2>
      <p class="section__lede">
        An archive shelf that keeps proof close by without forcing everything
        into the main narrative.
      </p>
    </header>

    <div class="evidence-list">
      {
        assets.map((asset) => (
          <a class="evidence-item" href={asset.href} download>
            <span class="evidence-item__type">{asset.type}</span>
            <span class="evidence-item__title">{asset.title}</span>
            <span class="evidence-item__note">{asset.note}</span>
            <span class="evidence-item__action" aria-hidden="true">
              Download ↓
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
