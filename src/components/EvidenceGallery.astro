---
import type { EvidenceAsset } from "../data/portfolio";

interface Props {
  assets: EvidenceAsset[];
}

const { assets } = Astro.props;
---

<section class="content-section section-shell" id="evidence">
  <div class="section-heading">
    <p class="eyebrow">Evidence gallery</p>
    <h2>A clean backup layer for documents, notes, and supporting material</h2>
    <p>
      This section is designed like an archive shelf. It keeps proof close by
      without forcing everything into the main narrative.
    </p>
  </div>

  <div class="evidence-grid">
    {
      assets.map((asset) => (
        <a class="surface-card evidence-card" href={asset.href} download>
          <div class="evidence-card__preview">
            <span>{asset.type}</span>
          </div>
          <div class="evidence-card__body">
            <div class="case-study__meta">
              <span class="badge badge--soft">{asset.type}</span>
            </div>
            <h3>{asset.title}</h3>
            {asset.note && <p>{asset.note}</p>}
          </div>
        </a>
      ))
    }
  </div>
</section>
