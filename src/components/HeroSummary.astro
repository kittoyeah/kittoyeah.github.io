---
import type { FeaturedWork, HeroSignal, SiteConfig } from "../data/portfolio";

interface Props {
  siteConfig: SiteConfig;
  signals: HeroSignal[];
  works: FeaturedWork[];
}

const { siteConfig, signals } = Astro.props;
---

<section class="hero" id="summary">
  <div class="container">
    <span class="hero__status">
      <span class="hero__status-dot" aria-hidden="true"></span>
      Available for early-career software roles
    </span>

    <h1>
      Chris <em>Kittichod</em>
    </h1>

    <p class="hero__role">{siteConfig.role} &mdash; Hobart, Tasmania</p>

    <p class="hero__tagline">{siteConfig.tagline}</p>
    <p class="hero__summary">{siteConfig.summary}</p>

    <div class="btn-row">
      <a
        class="btn btn--primary"
        href={siteConfig.primaryCta.href}
        rel="noreferrer"
        target="_blank"
      >
        {siteConfig.primaryCta.label}
        <span class="btn__arrow" aria-hidden="true">↗</span>
      </a>
      <a class="btn btn--ghost" href={siteConfig.secondaryCta.href}>
        {siteConfig.secondaryCta.label}
        <span class="btn__arrow" aria-hidden="true">↓</span>
      </a>
    </div>

    <dl class="hero__meta">
      {
        signals.map((signal) => (
          <div class="hero__meta-item">
            <dt class="hero__meta-label">{signal.label}</dt>
            <dd class="hero__meta-value">{signal.value}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
