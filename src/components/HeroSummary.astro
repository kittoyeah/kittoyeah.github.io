---
import type { FeaturedWork, HeroSignal, SiteConfig } from "../data/portfolio";

interface Props {
  siteConfig: SiteConfig;
  signals: HeroSignal[];
  works: FeaturedWork[];
}

const { siteConfig, signals } = Astro.props;
---

<section class="intro" id="summary">
  <span class="intro__tag">Open to software roles — 2026</span>

  <h1 class="intro__name" aria-label="Chris Kittichod">
    <span>Chris</span> <span class="is-pop">Kittichod</span>
  </h1>

  <div class="intro__row">
    <p class="intro__lede">{siteConfig.tagline}</p>

    <div>
      <p class="intro__role">Software Engineer · Hobart, Tasmania</p>
      <p class="intro__summary">{siteConfig.summary}</p>
    </div>
  </div>

  <div class="intro__actions">
    <a
      class="cta cta--solid"
      href={siteConfig.primaryCta.href}
      rel="noreferrer"
      target="_blank"
    >
      {siteConfig.primaryCta.label}
      <span class="cta__arr" aria-hidden="true">↗</span>
    </a>
    <a class="cta cta--ghost" href={siteConfig.secondaryCta.href}>
      {siteConfig.secondaryCta.label}
      <span class="cta__arr" aria-hidden="true">↓</span>
    </a>
  </div>

  <dl class="intro__stats">
    {
      signals.map((signal) => (
        <div>
          <dt class="intro__stat-key">{signal.label}</dt>
          <dd class="intro__stat-val">{signal.value}</dd>
        </div>
      ))
    }
  </dl>
</section>
