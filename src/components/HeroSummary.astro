---
import type { FeaturedWork, HeroSignal, SiteConfig } from "../data/portfolio";

interface Props {
  siteConfig: SiteConfig;
  signals: HeroSignal[];
  works: FeaturedWork[];
}

const { siteConfig, signals, works } = Astro.props;
const previewWorks = works.slice(0, 3);
---

<section class="hero section-shell" id="summary">
  <div class="hero__copy">
    <p class="eyebrow">Summary</p>
    <h1>{siteConfig.name}</h1>
    <p class="hero__role">{siteConfig.role}</p>
    <p class="hero__tagline">{siteConfig.tagline}</p>
    <p class="hero__summary">{siteConfig.summary}</p>

    <div class="button-row">
      <a
        class="button"
        href={siteConfig.primaryCta.href}
        rel="noreferrer"
        target="_blank"
      >
        {siteConfig.primaryCta.label}
      </a>
      <a class="button button--secondary" href={siteConfig.secondaryCta.href}>
        {siteConfig.secondaryCta.label}
      </a>
    </div>

    <ul class="hero-signals" aria-label="Quick profile signals">
      {
        signals.map((signal) => (
          <li class="signal-card">
            <span class="signal-card__label">{signal.label}</span>
            <strong>{signal.value}</strong>
          </li>
        ))
      }
    </ul>
  </div>

  <aside class="hero__visual" aria-label="Selected work previews">
    <div class="identity-card">
      <div class="identity-card__top">
        <div class="identity-card__monogram" aria-hidden="true">
          CK
        </div>
        <div>
          <p class="eyebrow eyebrow--compact">Current direction</p>
          <h2>From product framing to software delivery</h2>
        </div>
      </div>

      <dl class="identity-list">
        <div>
          <dt>Base</dt>
          <dd>Hobart, Tasmania</dd>
        </div>
        <div>
          <dt>Background</dt>
          <dd>Business analysis, product ownership, service design</dd>
        </div>
        <div>
          <dt>Build focus</dt>
          <dd>Practical web products, operational tooling, AI-enabled workflows</dd>
        </div>
        <div>
          <dt>Open to</dt>
          <dd>Internship, graduate, and early-career software roles</dd>
        </div>
      </dl>
    </div>

    <div class="hero-workstack">
      {
        previewWorks.map((work) => (
          <a class="hero-shot" href="#work">
            <img
              src={work.coverImage}
              alt={`${work.title} project preview`}
              loading="eager"
            />
            <span>{work.title}</span>
          </a>
        ))
      }
    </div>
  </aside>
</section>
