---
import type { ContactLink, SiteConfig } from "../data/portfolio";

interface Props {
  siteConfig: SiteConfig;
  contacts: ContactLink[];
  resumeHref: string;
}

const { siteConfig, contacts, resumeHref } = Astro.props;

const sorted = [...contacts].sort((a, b) => a.priority - b.priority);

const valueFor = (label: ContactLink["label"]) => {
  if (label === "LinkedIn") return "linkedin.com/in/chris-kittichod";
  if (label === "GitHub") return "github.com/kittoyeah";
  return "chris.kittichod@gmail.com";
};
---

<section class="ping" id="contact">
  <div class="ping__inner">
    <span class="ping__eyebrow">05 — Let&rsquo;s build something</span>

    <h2 class="ping__big">
      Got a <em>role</em><br />or a <em>problem</em>?
    </h2>

    <div class="ping__below">
      <div class="ping__copy">
        <p>
          If you are hiring for a software role, exploring product-minded
          engineering talent, or want someone who can move from discovery
          into delivery &mdash; I am open to that conversation.
        </p>
        <div class="intro__actions" style="margin-top: 2rem;">
          <a
            class="cta cta--solid"
            href={siteConfig.primaryCta.href}
            rel="noreferrer"
            target="_blank"
          >
            {siteConfig.primaryCta.label}
            <span class="cta__arr" aria-hidden="true">↗</span>
          </a>
          <a class="cta cta--ghost" href={resumeHref} download>
            Grab the resume
            <span class="cta__arr" aria-hidden="true">↓</span>
          </a>
        </div>
      </div>

      <div class="ping__links">
        {
          sorted.map((contact) => (
            <a
              class="ping-link"
              href={contact.href}
              rel="noreferrer"
              target={contact.label === "Email" ? undefined : "_blank"}
            >
              <span class="ping-link__label">{contact.label}</span>
              <span class="ping-link__val">{valueFor(contact.label)}</span>
              <span class="ping-link__arr" aria-hidden="true">
                ↗
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>
