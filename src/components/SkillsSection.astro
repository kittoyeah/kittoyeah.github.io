---
import type { SkillGroup } from "../data/portfolio";

interface Props {
  groups: SkillGroup[];
}

const { groups } = Astro.props;
---

<section class="kit" id="skills">
  <div class="kit__inner">
    <div class="slab" style="padding: 0;">
      <div class="slab__row">
        <span class="slab__key">Toolkit</span>
        <span class="slab__count">What I bring</span>
      </div>
    </div>

    <div class="heading" style="padding-left: 0; padding-right: 0;">
      <h2 class="heading__title">
        <em>Capability</em> first, tools second.
      </h2>
      <p class="heading__note">
        Tools are not identity. What matters is whether the work produces a
        useful outcome, handles constraints, and keeps improving after the
        first version ships.
      </p>
    </div>

    <div class="kit__grid">
      {
        groups.map((group, index) => (
          <article class="kit__card">
            <span class="kit__num">{String(index + 1).padStart(2, "0")}</span>
            <div class="kit__body">
              <h3 class="kit__name">{group.title}</h3>
              <p>{group.summary}</p>
              <div class="kit__tags">
                {group.items.map((item) => (
                  <span class="pill">{item}</span>
                ))}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
