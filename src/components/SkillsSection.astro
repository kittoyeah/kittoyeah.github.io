---
import type { SkillGroup } from "../data/portfolio";

interface Props {
  groups: SkillGroup[];
}

const { groups } = Astro.props;
---

<section class="section" id="skills">
  <div class="container">
    <header class="section__head">
      <span class="section__num">03 &mdash; Skills</span>
      <h2 class="section__title">Practical capability first, tools second.</h2>
      <p class="section__lede">
        Tools are not identity. What matters is whether the work produces a
        useful outcome, handles constraints, and keeps improving after the
        first version ships.
      </p>
    </header>

    <div class="skills-grid">
      {
        groups.map((group, index) => (
          <article class="skill-card">
            <span class="skill-card__num">
              /0{index + 1}
            </span>
            <h3>{group.title}</h3>
            <p>{group.summary}</p>
            <div class="skill-card__tags">
              {group.items.map((item) => (
                <span class="tag">{item}</span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
