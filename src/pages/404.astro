---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page not found | Chris Kittichod"
  description="The page you are looking for does not exist."
>
  <main class="nope">
    <span class="nope__code">Error 404</span>
    <h1>Nothing here.</h1>
    <p>
      The page you tried to open is not here. The homepage is the best place
      to start.
    </p>
    <a class="cta cta--solid" style="justify-self: start;" href="/">
      Return home
      <span class="cta__arr" aria-hidden="true">↗</span>
    </a>
  </main>
</BaseLayout>
