---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page not found | Chris Kittichod"
  description="The page you are looking for does not exist."
>
  <main class="not-found-shell section-shell">
    <p class="eyebrow">404</p>
    <h1>Page not found</h1>
    <p>
      The page you tried to open is not here. The portfolio homepage is the
      best place to start.
    </p>
    <a class="button" href="/">
      Return home
    </a>
  </main>
</BaseLayout>
