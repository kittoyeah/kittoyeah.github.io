---
import ContactSection from "../components/ContactSection.astro";
import EvidenceGallery from "../components/EvidenceGallery.astro";
import FeaturedWorkSection from "../components/FeaturedWorkSection.astro";
import Header from "../components/Header.astro";
import HeroSummary from "../components/HeroSummary.astro";
import SkillsSection from "../components/SkillsSection.astro";
import {
  contactLinks,
  evidenceAssets,
  featuredWork,
  heroSignals,
  sectionLinks,
  siteConfig,
  skillGroups,
} from "../data/portfolio";
import BaseLayout from "../layouts/BaseLayout.astro";

const year = new Date().getFullYear();
---

<BaseLayout
  title="Chris Kittichod | Software Engineer"
  description="Software engineer building practical products and agentic AI workflows that solve real problems."
>
  <div id="top">
    <Header siteConfig={siteConfig} sections={sectionLinks} />

    <main>
      <HeroSummary
        siteConfig={siteConfig}
        signals={heroSignals}
        works={featuredWork}
      />
      <FeaturedWorkSection works={featuredWork} />
      <SkillsSection groups={skillGroups} />
      <EvidenceGallery assets={evidenceAssets} />
      <ContactSection
        contacts={contactLinks}
        resumeHref="/assets/docs/chris-kittichod-resume.md"
        siteConfig={siteConfig}
      />
    </main>

    <footer class="footer">
      <div class="container footer__inner">
        <span>&copy; {year} Chris Kittichod</span>
        <span>Built with Astro &mdash; Hobart, TAS</span>
      </div>
    </footer>
  </div>
</BaseLayout>
